# Copy to ops/linear/runtime/symphony.env and fill required values.
# Keep secrets out of git: do not commit real API keys or tokens.
#
# Cross-platform defaults:
# - Leave storage/root keys unset unless you need a machine-specific override.
# - Symphony auto-detects an external artifact root per OS by default.

LINEAR_API_KEY=
MOLT_LINEAR_PROJECT_SLUG=
MOLT_SOURCE_REPO_URL=
MOLT_SYMPHONY_SYNC_REMOTE=origin
MOLT_SYMPHONY_SYNC_BRANCH=main
# Comma-separated author fragments allowed for auto-merge fast-forward sync.
MOLT_SYMPHONY_AUTOMERGE_ALLOWED_AUTHORS=adpena,symphony
# Comma-separated trusted user fragments and machine names for auto-land.
MOLT_SYMPHONY_TRUSTED_USERS=adpena,symphony
MOLT_SYMPHONY_TRUSTED_MACHINES=
# Auto-land controls:
MOLT_SYMPHONY_AUTOLAND_ENABLED=1
MOLT_SYMPHONY_AUTOLAND_MODE=direct-main
MOLT_SYMPHONY_AUTOLAND_COMMIT_MESSAGE=chore: sync all changes
MOLT_SYMPHONY_AUTOLAND_PR_AUTOMERGE=1
MOLT_SYMPHONY_AUTOLAND_PR_BASE=main
# Codex app-server token-efficiency defaults (override per machine as needed).
MOLT_SYMPHONY_CODEX_ARGS=-c model_reasoning_effort=low -c model_reasoning_summary=none -c hide_agent_reasoning=true -c model_verbosity=low -c tool_output_token_limit=6000 -c model_auto_compact_token_limit=120000

# Optional per-machine storage overrides (leave commented to use autodetect).
# MOLT_EXT_ROOT=
# MOLT_SYMPHONY_PARENT_ROOT=
# MOLT_SYMPHONY_PROJECT_KEY=molt
# MOLT_SYMPHONY_STORE_ROOT=
# CARGO_TARGET_DIR=
# MOLT_DIFF_CARGO_TARGET_DIR=
# MOLT_CACHE=
# MOLT_DIFF_ROOT=
# MOLT_DIFF_TMPDIR=
# MOLT_APALACHE_WORK_DIR=
# UV_CACHE_DIR=
# TMPDIR=

MOLT_SYMPHONY_TOOL_STATE_DETAIL=compact
MOLT_SYMPHONY_MAX_CODEX_EVENT_COUNTERS=64
MOLT_SYMPHONY_DURABLE_MEMORY=1
MOLT_SYMPHONY_LOOP_HOOK_CMD=
MOLT_SYMPHONY_DURABLE_SYNC_SECONDS=180

# Optional DSPy-assisted routing.
MOLT_SYMPHONY_DSPY_ENABLE=0
MOLT_SYMPHONY_DSPY_MODEL=openai/gpt-4.1-mini
MOLT_SYMPHONY_DSPY_API_KEY_ENV=OPENAI_API_KEY
# Optional direct key override (discouraged in committed files):
# MOLT_SYMPHONY_DSPY_API_KEY=

# Optional formal-toolchain overrides.
MOLT_QUINT_NODE_FALLBACK='npx -y node@22'
# JAVA_HOME=/path/to/jdk

# Optional API hardening overrides.
# MOLT_SYMPHONY_API_TOKEN=replace-with-long-random-token
# MOLT_SYMPHONY_API_TOKEN_FILE=/path/to/secrets/dashboard_api_token
MOLT_SYMPHONY_SECURITY_PROFILE=local
MOLT_SYMPHONY_BIND_HOST=127.0.0.1
MOLT_SYMPHONY_ALLOW_NONLOCAL_BIND=0
MOLT_SYMPHONY_ALLOW_QUERY_TOKEN=1
MOLT_SYMPHONY_DISABLE_DASHBOARD_UI=0
MOLT_SYMPHONY_ENFORCE_ORIGIN=1
MOLT_SYMPHONY_REQUIRE_CSRF_HEADER=1
# MOLT_SYMPHONY_ALLOWED_ORIGINS=http://127.0.0.1:8089,http://localhost:8089

# Capacity/backpressure controls for HTTP + orchestrator event ingestion.
MOLT_SYMPHONY_MAX_HTTP_CONNECTIONS=96
MOLT_SYMPHONY_MAX_STREAM_CLIENTS=16
MOLT_SYMPHONY_STREAM_MAX_AGE_SECONDS=300
MOLT_SYMPHONY_HTTP_RATE_LIMIT_MAX_REQUESTS=240
MOLT_SYMPHONY_HTTP_RATE_LIMIT_WINDOW_SECONDS=60
MOLT_SYMPHONY_EVENT_QUEUE_MAX=8192
MOLT_SYMPHONY_EVENT_QUEUE_DROP_LOG_INTERVAL=250

# Optional: compiled helper for state ETag hashing.
# MOLT_SYMPHONY_STATE_HASH_HELPER=/path/to/bin/symphony_state_hasher_molt
MOLT_SYMPHONY_STATE_HASH_HELPER_PREFER_FRAME=1
MOLT_SYMPHONY_STATE_HASH_HELPER_TIMEOUT_MS=150
