+
+  llvm-backend:
+    name: LLVM Backend
+    runs-on: ubuntu-latest
+    steps:
+      - uses: actions/checkout@v5
+
+      - uses: dtolnay/rust-toolchain@stable
+
+      - name: Configure adaptive Rust parallelism
+        run: python3 tools/ci_resource_env.py --github-env "$GITHUB_ENV"
+
+      - uses: Swatinem/rust-cache@v2
+
+      # The LLVM backend is gated behind the `llvm` cargo feature and links
+      # against inkwell/llvm-sys, which require the matching LLVM toolchain.
+      # The required major version is derived from the inkwell feature pin in
+      # runtime/molt-backend/Cargo.toml (e.g. `llvm21-1` -> LLVM 21).
+      - name: Resolve required LLVM major version
+        id: llvmver
+        run: |
+          MAJOR=$(grep -oE 'features\s*=\s*\[[^]]*"llvm([0-9]+)-[0-9]+"' \
+            runtime/molt-backend/Cargo.toml | grep -oE 'llvm[0-9]+' | grep -oE '[0-9]+' | head -1)
+          if [ -z "$MAJOR" ]; then echo "::error::could not resolve LLVM major"; exit 1; fi
+          echo "major=$MAJOR" >> "$GITHUB_OUTPUT"
+          echo "Required LLVM major: $MAJOR"
+
+      - name: Install LLVM toolchain
+        run: |
+          MAJOR="${{ steps.llvmver.outputs.major }}"
+          # Upstream LLVM apt installer (apt.llvm.org) provides per-major builds.
+          wget -qO /tmp/llvm.sh https://apt.llvm.org/llvm.sh
+          chmod +x /tmp/llvm.sh
+          sudo /tmp/llvm.sh "$MAJOR"
+          sudo apt-get install -y "llvm-$MAJOR-dev" "libpolly-$MAJOR-dev" lld
+          # llvm-sys discovers the install via LLVM_SYS_<major>1_PREFIX.
+          echo "LLVM_SYS_${MAJOR}1_PREFIX=$(llvm-config-$MAJOR --prefix)" >> "$GITHUB_ENV"
+          "llvm-config-$MAJOR" --version
+
+      # Deterministic regression gate for the integer-overflow miscompile.
+      # The LLVM backend used to emit raw machine add/sub/mul on any TirType::I64
+      # and mask to 47 bits with no BigInt promotion, so integers crossing 2**47
+      # produced wrong results only on this backend. These unit tests assert the
+      # IR routes non-overflow-safe integer arithmetic through molt_add and keeps
+      # the raw path only for plan-proven overflow-safe carriers.
+      - name: Build molt-backend with the llvm feature
+        run: |
+          mkdir -p logs
+          set -o pipefail
+          python3 tools/guarded_exec.py --prefix MOLT_TEST_SUITE -- \
+            cargo build -p molt-backend --features "native-backend llvm" 2>&1 \
+            | tee logs/ci-llvm-build.log
+
+      - name: Verify zero warnings (llvm feature)
+        run: |
+          WARNING_COUNT=$(grep -c 'warning\[' logs/ci-llvm-build.log || true)
+          echo "Warnings found: $WARNING_COUNT"
+          if [ "$WARNING_COUNT" -ne 0 ]; then
+            echo "::error::LLVM build produced $WARNING_COUNT warning(s)."
+            grep 'warning\[' logs/ci-llvm-build.log || true
+            exit 1
+          fi
+
+      # Scope to the `llvm_backend::lowering` test module so this stays a green,
+      # deterministic gate for the integer-overflow miscompile (and all LLVM
+      # lowering invariants). The broader `tests::` module contains a separate,
+      # pre-existing failing stdlib-partition test
+      # (`llvm_backend_keeps_shared_stdlib_partition_external`) tracked apart from
+      # this fix; it must not mask overflow regressions here.
+      - name: Run LLVM lowering + int-overflow regression tests
+        run: |
+          python3 tools/guarded_exec.py --prefix MOLT_TEST_SUITE -- \
+            cargo test -p molt-backend --features "native-backend llvm" --lib llvm_backend::lowering
+
+      - name: Clippy (molt-backend, llvm feature)
+        run: |
+          python3 tools/guarded_exec.py --prefix MOLT_TEST_SUITE -- \
+            cargo clippy -p molt-backend --features "native-backend llvm" --lib -- -D warnings
+
+      - uses: actions/setup-python@v6
+        with:
+          python-version-file: ".python-version"
+
+      - uses: astral-sh/setup-uv@v8.1.0
+
+      - name: Sync Python environment
+        run: uv sync --frozen --group dev
+
+      # End-to-end differential gate: build integer-overflow programs through the
+      # LLVM backend and compare stdout against CPython and the native backend.
+      # This is the build/run/compare gate the cross-backend audit asked for.
+      #
+      # NOTE: this step is currently `continue-on-error` because the LLVM backend
+      # has a SEPARATE, pre-existing, flaky stdlib-partition pipeline crash
+      # (`[TIR] verification failed ... entry block ^bb0 does not exist` while
+      # compiling `molt_init___future__` / `_Feature.__init__`) that intermittently
+      # aborts the build before the overflow program runs. That bug is independent
+      # of the integer-overflow fix and already has its own failing unit test
+      # (`tests::llvm_backend_keeps_shared_stdlib_partition_external`). The
+      # deterministic IR-level regression for the overflow miscompile is the hard
+      # gate above (`cargo test ... --lib llvm_backend`). Once the stdlib-partition
+      # crash is fixed, drop `continue-on-error` to make this a blocking gate.
+      - name: LLVM int-overflow differential tests (build/run vs CPython)
+        continue-on-error: true
+        env:
+          MOLT_NATIVE_TEST_TIMEOUT_SEC: "900"
+        run: |
+          python3 tools/guarded_exec.py --prefix MOLT_TEST_SUITE -- \
+            uv run python3 -m pytest -q \
+            tests/test_native_lir_loop_join_semantics.py \
+            -k "int_accumulator_crosses_47 or int_overflows_i64 or int_sum_accumulator_overflow or non_overflowing_int_loop"
+
+      - name: Summarize guarded command hotspots
+        if: always()
+        run: python3 tools/profile_hotspots.py --limit 20
