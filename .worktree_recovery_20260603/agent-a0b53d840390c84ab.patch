--- a/Cargo.toml
+++ b/Cargo.toml
@@ -337,8 +337,26 @@ panic = "abort"
 strip = true
 
 # Size-optimized release profile for micro stdlib builds.
-# Uses opt-level "z" (minimize binary size) with fat LTO and single codegen
-# unit for maximum cross-crate inlining and dead code elimination.
+# Uses opt-level "z" (minimize binary size) at profile scope with fat LTO and a
+# single codegen unit for maximum cross-crate inlining and dead code
+# elimination. The four hot runtime crates are re-asserted to opt-"s" below
+# (see the hot-crate opt-level policy block) so they do not silently ride at the
+# opt-3 inherited from `release`.
+#
+# panic = "unwind" is DELIBERATE here, not an oversight (audit F5): unlike
+# `wasm-release` (whose wasm target never uses catch_unwind, so abort is free)
+# and `release-output`, `release-size` is the size-optimized NATIVE profile and
+# CAN be selected (via `--profile`/`MOLT_RELEASE_CARGO_PROFILE`) to build the
+# native runtime staticlib, whose 599 catching `with_gil_entry!` stdlib FFI
+# sites (`runtime/molt-runtime/src/concurrency/mod.rs:40`,
+# `runtime/molt-runtime-core/src/lib.rs:156`) rely on unwinding to convert a Rust
+# panic into a catchable Python exception. Flipping to `panic = "abort"` here
+# would make those catch_unwind sites no-ops (a CPython parity divergence, the
+# same class as audit F1). The abort switch for the native runtime is gated on
+# the not-yet-landed panic-macro (`cfg(panic)`) unification that migrates those
+# sites to panic-free error propagation; until that lands, `unwind` is the
+# correct, safe choice and the ~750KB unwind-table cost is accepted. Do NOT flip
+# to abort independently of that work.
 [profile.release-size]
 inherits = "release"
 opt-level = "z"
@@ -350,6 +368,10 @@ strip = true
 # WASM-optimized release profile: fat LTO with single codegen unit for
 # maximum cross-crate inlining and dead code elimination. Build time
 # increases but runtime wasm artifacts are cached and infrequently rebuilt.
+# NOTE: the profile-scope opt-level="z" below governs bulk stdlib crates only;
+# the four hot runtime crates are re-asserted to opt-"s" in the hot-crate
+# opt-level policy block (they would otherwise inherit opt-3 from `release` and
+# inflate the shipped runtime by ~1.65 MB / 25.5%, measured).
 [profile.wasm-release]
 inherits = "release"
 opt-level = "z"  # minimize binary size for Cloudflare Workers 3MB limit
@@ -381,11 +403,34 @@ opt-level = 3
 [profile.release.package.regalloc2]
 opt-level = 3
 
-# Optimize runtime crates — statically linked into output binaries.
-# Runtime packages: opt-level 3 for maximum native performance.
-# The WASM/size-optimized builds use profile.wasm-release (opt="z").
-# These are the hot-path functions called millions of times — every
-# bit of inlining, vectorization, and scheduling matters.
+# ── Hot runtime crate opt-level policy (per profile family) ──────────────────
+#
+# IMPORTANT inheritance fact (verified with `cargo build -v`): Cargo per-package
+# overrides set on a *parent* profile ARE inherited by child profiles via
+# `inherits` unless the child re-declares the same `[profile.<child>.package.X]`
+# table. So the opt-level=3 hot-crate overrides below propagate from `release`
+# into every `inherits = "release"` child — including the *size* profiles
+# (`release-size`, `wasm-release`). That is correct for the speed profiles
+# (`release`, `release-fast`, `release-output`, `dev-release`) but WRONG for the
+# size profiles: it silently lifted the hot crates to opt-3 there, defeating the
+# size profiles' stated goal.
+#
+# Measured effect on the shipped wasm runtime cdylib (strip + wasm-opt -Oz):
+#   opt-3 hot crates (old, leaked): 6,809,756 bytes
+#   opt-s hot crates (re-asserted):  5,075,011 bytes  → 1.65 MB (25.5%) smaller
+# (opt-"s" and opt-"z" produced byte-identical wasm here; "s" is chosen to keep
+#  speed-leaning optimizations for the perf-vs-CPython contract at no size cost.)
+#
+# So: the SPEED profiles keep the hot crates at opt-3 (below); the SIZE profiles
+# re-assert opt-"s" on the same crates (further below). Bulk stdlib crates stay
+# at each profile's own opt-level (3 for speed, "z" for size) via the default.
+
+# Speed profiles (release / release-fast / release-output / dev-release): the
+# hot-path object-model + arith + container functions are called millions of
+# times — every bit of inlining, vectorization, and scheduling matters, so
+# opt-3 even though the surrounding profile may select a smaller default
+# (release-output is opt-"z" at profile scope; these overrides keep the hot
+# crates at 3, verified shipping at opt-3 via `cargo build -v`).
 [profile.release.package.molt-runtime]
 opt-level = 3
 codegen-units = 1
@@ -398,3 +443,66 @@ opt-level = 3
 
 [profile.release.package.molt-runtime-collections]
 opt-level = 3
+
+# Size profiles (release-size / wasm-release): re-assert opt-"s" on the four hot
+# runtime crates, overriding the opt-3 inherited from `release` above. "s"
+# (optimize for size, retaining cheap speed wins) gives the full 25.5% wasm size
+# reduction measured above while protecting the faster-than-CPython contract
+# better than "z" would. codegen-units=1 is preserved for cross-crate DCE.
+[profile.release-size.package.molt-runtime]
+opt-level = "s"
+codegen-units = 1
+
+[profile.release-size.package.molt-runtime-core]
+opt-level = "s"
+
+[profile.release-size.package.molt-lang-obj-model]
+opt-level = "s"
+
+[profile.release-size.package.molt-runtime-collections]
+opt-level = "s"
+
+[profile.wasm-release.package.molt-runtime]
+opt-level = "s"
+codegen-units = 1
+
+[profile.wasm-release.package.molt-runtime-core]
+opt-level = "s"
+
+[profile.wasm-release.package.molt-lang-obj-model]
+opt-level = "s"
+
+[profile.wasm-release.package.molt-runtime-collections]
+opt-level = "s"
+
+# Fallback profile for the wasm runtime recovery path (cli.py
+# MOLT_WASM_RUNTIME_FALLBACK_PROFILE). It MUST preserve wasm-release's size +
+# panic contract (opt size, panic=abort, strip) — switching the fallback to
+# `release-fast` (opt-3, panic=unwind) re-introduced unwind tables and inflated
+# the artifact past the 3MB Cloudflare ceiling. The ONLY differences from
+# wasm-release are the codegen knobs that change to escape the fat-LTO single-CGU
+# corruption class a fallback is recovering from: thin LTO + 16 codegen units,
+# applied to ALL crates including the hot ones (the hot crates would otherwise
+# keep codegen-units=1 from the inherited `release` package override and so be
+# exempt from the very relaxation the fallback exists to apply). Same opt-"s"
+# hot-crate re-assertion as wasm-release so size stays bounded.
+[profile.wasm-release-fallback]
+inherits = "wasm-release"
+lto = "thin"
+codegen-units = 16
+
+[profile.wasm-release-fallback.package.molt-runtime]
+opt-level = "s"
+codegen-units = 16
+
+[profile.wasm-release-fallback.package.molt-runtime-core]
+opt-level = "s"
+codegen-units = 16
+
+[profile.wasm-release-fallback.package.molt-lang-obj-model]
+opt-level = "s"
+codegen-units = 16
+
+[profile.wasm-release-fallback.package.molt-runtime-collections]
+opt-level = "s"
+codegen-units = 16
