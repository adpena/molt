+        // ── 1b. Dead-on-arrival owned results (zero-use drop at def site) ─────
+        // The §1 last-use scan is keyed by OPERAND uses: a value never used as an
+        // operand never appears in `last_use`, so a freshly-minted OWNED value
+        // with ZERO subsequent uses (e.g. an expression-statement constructor
+        // `Foo()` whose binding + `del` were optimized away to a bare `call_bind`
+        // result) would otherwise NEVER be dropped. On the tracked-RC native lane
+        // its release was supplied by the value-tracking substrate; on the
+        // drop-pass lanes (LLVM / WASM / activated native) the drop pass is the
+        // SOLE RC authority, so an undropped owned temporary leaks AND — when its
+        // class defines `__del__` — silently skips finalizer dispatch (the
+        // refcount never reaches zero through `dec_ref_ptr`). Release such a value
+        // immediately after its defining op: its definition IS its last point of
+        // liveness. Same soundness rails as §1 (droppable root, not live-out, not
+        // transferred by a branch arg or the terminator), plus the §2.8
+        // conditional-iterator exclusion (those results are valid only on the
+        // not-done branch and are released by the body-path last-use rule, never
+        // at the def — dropping one at def would UAF the stale done-path slot).
+        for (idx, op) in block.ops.iter().enumerate() {
+            for &result in &op.results {
+                // Only fresh-owned ROOTS that are never used as an operand here.
+                if !droppable(result) {
+                    continue;
+                }
+                if last_use.contains_key(&result) {
+                    continue; // used in-block → handled by §1.
+                }
+                if iter_cond_value_results.contains(&result) {
+                    continue; // conditionally-valid (not-done only) → §1 body path.
+                }
+                if branch_arg_roots.contains(&result) {
+                    continue; // transferred on an edge → successor owns it.
+                }
+                if live.is_live_out(bid, result) {
+                    continue; // used in a later block → dropped there.
+                }
+                if terminator_uses_root(&block.terminator, result, &canon) {
+                    continue; // returned / branch-cond → ownership transferred.
+                }
+                plan.after_op.entry(idx).or_default().push(result);
+            }
+        }
