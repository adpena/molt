diff --git a/Cargo.toml b/Cargo.toml
index 993e0da98..b92426a87 100644
--- a/Cargo.toml
+++ b/Cargo.toml
@@ -293,7 +293,17 @@ debug = 0
 inherits = "release"
 opt-level = 3          # O3: auto-vectorization + aggressive inlining for daemon hot paths
 lto = "fat"
-codegen-units = 1
+# codegen-units controls only the PRE-LTO per-crate partitioning here: fat LTO
+# re-merges every crate's bitcode into a single module and re-optimizes the whole
+# program, so the initial cgu count has negligible effect on the final binary's
+# runtime perf (rustc fat-LTO semantics) but DOES parallelize each crate's
+# MIR->LLVM codegen across cores. release-fast is a build-ITERATION profile (the
+# backend daemon + runtime staging), not a ship profile — the shipping native
+# runtime is built with release-output and WASM with wasm-release, both of which
+# keep codegen-units=1. So we use a high cgu here purely to parallelize the
+# incremental recompile of the 342k-LoC molt-runtime hub (cgu=1 serialized it
+# into a ~72s one-line-edit rebuild; cgu=256 parallelizes it across 18 cores).
+codegen-units = 256
 strip = "symbols"
 panic = "unwind"       # required for catch_unwind in Cranelift retry path
 
@@ -307,6 +317,19 @@ opt-level = 3
 [profile.release-fast.package.regalloc2]
 opt-level = 3
 
+# Override the inherited [profile.release.package.molt-runtime] codegen-units = 1
+# for the build-iteration profile. Without this explicit override, release-fast
+# would inherit the ship-tuned cgu=1 from the base release profile and serialize
+# the 342k-LoC hub's codegen into a single unit (~72s for a one-line edit). Under
+# fat LTO the cgu count does not change final perf (whole-program re-merge), so
+# raising it is a pure incremental-rebuild win. opt-level stays 3 to match the
+# release-fast intent (the daemon-adjacent runtime staging should be optimized).
+# The SHIPPING runtime staticlib is built with release-output (cgu=1, untouched),
+# so this does NOT regress shipped runtime performance.
+[profile.release-fast.package.molt-runtime]
+opt-level = 3
+codegen-units = 256
+
 # Output-binary profile: used when building the runtime staticlib that gets
 # linked into user output binaries. Key differences from release-fast:
 #
