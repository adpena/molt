+            ops.iter().any(|op| matches!(
+                op.kind.as_str(),
+                "label" | "state_label"
+            ) && op.value == Some(36)),
+            "loop cond label (36) must remain materialized when re-entered \
+             from outside the region: {ops:?}"
+        );
+    }
