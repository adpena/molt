+                let block = *block;
+                if !visited.contains(&block) {
+                    continue;
+                }
+                if builder.func.layout.block_insts(block).next().is_none() {
+                    panic!(
+                        "native codegen left REACHABLE block {block:?} empty (no terminator) \
