+/// FinalizerRegion (doc 48): drain pending `__del__`s at a value-based boundary.
+/// Emitted by the backend at a compiled safe point AFTER a `del`/DecRef release
+/// (Phase 2E) so a plain `del x` finalizes promptly without an explicit
+/// `gc.collect()`, and never runs `__del__` inline inside `dec_ref_ptr`.
+#[unsafe(no_mangle)]
+pub extern "C" fn molt_drain_pending_finalizers() -> u64 {
+    crate::with_gil_entry_nopanic!(_py, {
+        unsafe { crate::object::drain_pending_finalizers(_py) };
+        MoltObject::none().bits()
+    })
+}
