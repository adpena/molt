 /// # Safety
 /// Caller must pass a valid object pointer and matching header.
+thread_local! {
+    // FinalizerRegion (doc 48): raw pointers to objects whose rc has hit 0 and
+    // whose `__del__` must run at a value-based drain boundary, NOT inline inside
+    // `dec_ref_ptr`. Entries sit at refcount 0, SCHEDULED, UNFREED (the moral
+    // equivalent of CPython's pending-finalizer state) until drained. GIL-held,
+    // so a thread-local (per-GIL) is sufficient.
+    static PENDING_FINALIZERS: std::cell::RefCell<Vec<*mut u8>> =
+        const { std::cell::RefCell::new(Vec::new()) };
+}
