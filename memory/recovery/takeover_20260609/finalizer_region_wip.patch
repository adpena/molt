+/// Schedule a finalizer-sensitive object for deferred drain (doc 48). Returns
+/// `true` when the object was scheduled — the caller (`dec_ref_ptr`) must then
+/// NOT free it: the drain will run `__del__` at a value-based boundary and then
+/// free it. CRITICAL: do NOT `inc_ref`/root — `maybe_run_object_finalizer`
+/// assumes a refcount-0 object (it inc→1, runs, dec→0, treats `prev>1` as
+/// resurrection); rooting would manufacture a false resurrection. Idempotent:
+/// an already-SCHEDULED object returns `true` without re-queueing.
+unsafe fn schedule_object_finalizer(py: &PyToken<'_>, ptr: *mut u8) -> bool {
+    let header_ptr = unsafe { header_from_obj_ptr(ptr) };
+    if (unsafe { (*header_ptr).flags } & HEADER_FLAG_FINALIZER_SCHEDULED) != 0 {
+        return true;
+    }
+    if !unsafe { object_has_runnable_finalizer(py, ptr) } {
+        if std::env::var_os("MOLT_TRACE_FIN65").is_some() {
+            eprintln!("[FIN65-SCHED] NO type_id={}", unsafe { (*header_ptr).type_id });
+        }
+        return false;
+    }
+    if std::env::var_os("MOLT_TRACE_FIN65").is_some() {
+        eprintln!("[FIN65-SCHED] YES type_id={}", unsafe { (*header_ptr).type_id });
+    }
+    unsafe {
+        (*header_ptr).flags |= HEADER_FLAG_FINALIZER_SCHEDULED;
+    }
+    PENDING_FINALIZERS.with(|q| q.borrow_mut().push(ptr));
+    true
+}
