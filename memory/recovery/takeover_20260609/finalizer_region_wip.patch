+/// Drain every pending finalizer through the single unraisable authority
+/// (`maybe_run_object_finalizer`), at a VALUE-BASED boundary (gc.collect /
+/// `molt_drain_pending_finalizers` / process teardown) where a raised `__del__`
+/// does NOT unwind past this runtime frame. Re-entrant safe: `__del__`s that
+/// schedule further finalizers are drained in the same loop.
+pub(crate) unsafe fn drain_pending_finalizers(py: &PyToken<'_>) {
+    loop {
+        let Some(ptr) = PENDING_FINALIZERS.with(|q| q.borrow_mut().pop()) else {
+            break;
+        };
+        let header_ptr = unsafe { header_from_obj_ptr(ptr) };
+        unsafe {
+            (*header_ptr).flags &= !HEADER_FLAG_FINALIZER_SCHEDULED;
+        }
+        // Run `__del__` at refcount 0. NOTE (#65, PROVEN): a raise inside
+        // `__del__` is molt's CUSTOM native unwind to the nearest COMPILED
+        // landing pad — it is NOT a Rust panic (catch_unwind does not catch it)
+        // and NOT controlled by `exception_stack_baseline`. So when run from this
+        // Rust drain frame (no compiled landing pad above), a standalone
+        // finalizer's raise unwinds straight past the swallow. The swallow only
+        // runs when a compiled landing pad exists above (e.g. composed via prior
+        // finalizers). The complete fix needs a COMPILED landing pad around the
+        // finalizer execution (backend/frontend) — see doc 48 / baton.
+        let resurrected = unsafe { maybe_run_object_finalizer(py, ptr) };
+        if resurrected {
+            // Alive again (rc>0); FINALIZER_RAN is set so it won't re-run. A later
+            // final drop re-enters `dec_ref_ptr` and frees it then.
+            continue;
+        }
+        // Not resurrected: rc 0, `__del__` done, FINALIZER_RAN set. Free it by
+        // RE-ENTERING `dec_ref_ptr`'s existing free path — which now sees
+        // FINALIZER_RAN set (so `schedule_object_finalizer` returns false) and
+        // runs the one true free tail. No duplicated free path (doc 48).
+        let self_bits = MoltObject::from_ptr(ptr).bits();
+        inc_ref_bits(py, self_bits);
+        unsafe {
+            dec_ref_ptr(py, ptr);
+        }
+    }
+}
