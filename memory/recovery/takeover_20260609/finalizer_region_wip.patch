+/// True iff `ptr` is a `TYPE_ID_OBJECT` whose class defines a runnable `__del__`
+/// — the SAME predicate `maybe_run_object_finalizer` uses to decide it will call
+/// `__del__` (correct type, finalizer not already run, resolvable non-traceback/
+/// frame class, `__del__` present on the MRO). The single finalizer-sensitivity
+/// authority, shared by scheduling and (implicitly) the drain.
+unsafe fn object_has_runnable_finalizer(py: &PyToken<'_>, ptr: *mut u8) -> bool {
+    let header_ptr = unsafe { header_from_obj_ptr(ptr) };
+    if unsafe { (*header_ptr).type_id } != TYPE_ID_OBJECT {
+        return false;
+    }
+    if (unsafe { (*header_ptr).flags } & HEADER_FLAG_FINALIZER_RAN) != 0 {
+        return false;
+    }
+    let cold_idx = unsafe { (*header_ptr).cold_idx };
+    let class_state = get_cold_header(cold_idx_real(cold_idx))
+        .map(|cold| cold.state)
+        .unwrap_or(0);
+    let class_bits = unsafe { object_class_bits_from_state(class_state) };
+    let Some(class_ptr) = obj_from_bits(class_bits).as_ptr() else {
+        return false;
+    };
+    let class_name = unsafe {
+        crate::string_obj_to_owned(obj_from_bits(layout::class_name_bits(class_ptr)))
+    };
+    if class_bits == crate::builtin_classes(py).traceback
+        || class_name.as_deref() == Some("traceback")
+        || class_bits == crate::builtin_classes(py).frame
+        || class_name.as_deref() == Some("frame")
+    {
+        return false;
+    }
+    let Some(del_name_bits) = crate::attr_name_bits_from_bytes(py, b"__del__") else {
+        return false;
+    };
+    // Detect `__del__` via the CLASS MRO (the class object is alive). NEVER do an
+    // INSTANCE attribute lookup on the refcount-0 object — that aliases a dead
+    // object's raw header (the #65-fix SIGSEGV). `maybe_run_object_finalizer`
+    // revives via `inc_ref` before any instance access because it RUNS `__del__`;
+    // here we only DETECT, so the class MRO suffices and the dead instance is
+    // never touched. The result is a borrowed ref (raw lookup) — do not dec it.
+    let found = unsafe {
+        crate::builtins::attr::class_attr_lookup_raw_mro(py, class_ptr, del_name_bits).is_some()
+    };
+    dec_ref_bits(py, del_name_bits);
+    found
+}
